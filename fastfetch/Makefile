include $(TOPDIR)/rules.mk

PKG_NAME:=fastfetch
PKG_VERSION:=2026.06.11~2edc41d
PKG_RELEASE:=1

PKG_SOURCE_PROTO:=git
PKG_SOURCE_URL:=https://github.com/fastfetch-cli/fastfetch.git
PKG_SOURCE_DATE:=2026-06-11
PKG_SOURCE_VERSION:=2edc41dd9ae16a0765846e7e750b66520eb1e64f
PKG_MIRROR_HASH:=d7c46b09985bc746eb8c4044b265d7263e445350e786532d7e51506875c45a37

PKG_MAINTAINER:=Albrecht Lohofener <albrecht@albrechtloh.de>
PKG_LICENSE:=MIT
PKG_LICENSE_FILES:=LICENSE
PKG_CPE_ID:=cpe:/a:fastfetch-cli:fastfetch

include $(INCLUDE_DIR)/package.mk
include $(INCLUDE_DIR)/cmake.mk

TARGET_CFLAGS += -ffunction-sections -fdata-sections -fno-unwind-tables -fno-asynchronous-unwind-tables
TARGET_LDFLAGS += -Wl,--gc-sections

define Package/fastfetch
  SECTION:=utils
  CATEGORY:=Utilities
  TITLE:=Fast neofetch-like system information tool
  URL:=https://github.com/fastfetch-cli/fastfetch
endef

define Package/fastfetch/description
 Fastfetch is a neofetch-like tool for fetching system information
 and displaying it in a visually appealing way.
endef

define Build/Prepare
	$(call Build/Prepare/Default)
	cp -fp $(PKG_BUILD_DIR)/src/logo/ascii/o/openwrt.txt $(PKG_BUILD_DIR)/openwrt.txt
	rm -rf $(PKG_BUILD_DIR)/src/logo/ascii/[a-z]
	$(INSTALL_DIR) $(PKG_BUILD_DIR)/src/logo/ascii/o
	mv -f $(PKG_BUILD_DIR)/openwrt.txt $(PKG_BUILD_DIR)/src/logo/ascii/o/openwrt.txt
endef

